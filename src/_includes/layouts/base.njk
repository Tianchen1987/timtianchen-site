<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if title %}{{ title }} · {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
    <meta name="description" content="{{ description or summary or site.description }}" />
    <meta property="og:title" content="{% if title %}{{ title }}{% else %}{{ site.title }}{% endif %}" />
    <meta property="og:description" content="{{ description or summary or site.description }}" />
    <meta property="og:type" content="{% if categories %}article{% else %}website{% endif %}" />
    {% if hero %}<meta property="og:image" content="{{ site.url }}{{ hero }}" />{% endif %}
    <link rel="stylesheet" href="/css/style.css" />
    <link
      rel="alternate"
      type="application/atom+xml"
      href="/feed.xml"
      title="{{ site.title }}"
    />
  </head>
  <body>
    <header class="site-header">
      <a class="site-title" href="/">{{ site.title }}</a>
      <p class="site-tagline">{{ site.description }}</p>
      <nav class="site-nav">
        <a href="/">Home</a>
        <a href="/about/">About</a>
      </nav>
    </header>
    <main class="{% if wide %}wide{% endif %}">{{ content | safe }}</main>
    <footer class="site-footer">
      <p>timtianchen.com</p>
    </footer>
  </body>
</html>
