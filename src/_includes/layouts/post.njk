---
layout: layouts/base.njk
---
<article class="post">
  <header class="post-header">
    <time class="post-date" datetime="{{ page.date | isoDate }}">{{ page.date | readableDate }}</time>
    <h1>{{ title }}</h1>
    {% if categories %}
      <p class="post-tags">
        {% for c in categories %}<a class="tag" href="/#{{ c | categorySlug }}">{{ c }}</a>{% endfor %}
      </p>
    {% endif %}
  </header>
  <div class="post-body">{{ content | safe }}</div>
  <nav class="post-footer-nav"><a href="/">← All posts</a></nav>
</article>
